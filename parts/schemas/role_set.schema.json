{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["name", "roles", "critical_roles"],
  "properties": {
    "name": {"type": "string"},
    "roles": {"type": "object", "additionalProperties": {"type": "object", "required": ["component_id", "resolution"]}},
    "alternatives": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["component_id", "resolution", "rationale"],
          "properties": {
            "component_id": {"type": "string"},
            "resolution": {"type": "string"},
            "rationale": {"type": "string"},
            "required_reviews": {"type": "array", "items": {"type": "string"}},
            "compatibility": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "pin_numbers": {"type": "string"},
                "footprint": {"type": "string"},
                "electrical_value": {"type": "string"}
              }
            }
          }
        }
      }
    },
    "single_source_justifications": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["reason", "mitigation", "required_reviews"],
        "properties": {
          "reason": {"type": "string"},
          "mitigation": {"type": "string"},
          "required_reviews": {"type": "array", "items": {"type": "string"}, "minItems": 1}
        }
      }
    },
    "critical_roles": {"type": "array", "items": {"type": "string"}}
  }
}
