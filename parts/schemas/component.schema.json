{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["components"],
  "properties": {
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "mpn", "manufacturer", "package", "symbol", "footprint", "pins", "lifecycle", "sourcing", "constraints", "resolution_provenance", "review_status"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "mpn": {"type": "string", "minLength": 1},
          "manufacturer": {"type": "string", "minLength": 1},
          "package": {"type": "string", "minLength": 1},
          "symbol": {
            "type": "object",
            "required": ["library_id", "verified", "expected_pins"],
            "properties": {"library_id": {"type": "string"}, "verified": {"const": true}, "expected_pins": {"type": "array", "minItems": 1, "items": {"type": "string"}}}
          },
          "footprint": {
            "type": "object",
            "required": ["library_id", "verified", "expected_pads"],
            "properties": {"library_id": {"type": "string"}, "verified": {"const": true}, "expected_pads": {"type": "array", "minItems": 1, "items": {"type": "string"}}}
          },
          "pins": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["number", "name", "electrical_type"]}},
          "lifecycle": {"enum": ["active", "nrnd", "obsolete"]},
          "sourcing": {"type": "object", "required": ["status", "supplier_skus"], "properties": {"status": {"enum": ["resolved", "waived", "unresolved"]}, "supplier_skus": {"type": "array"}}},
          "constraints": {"type": "array"},
          "resolution_provenance": {"type": "object", "required": ["source", "reviewed_at"]},
          "review_status": {"enum": ["approved", "pending", "rejected"]}
        }
      }
    }
  }
}
