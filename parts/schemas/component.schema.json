{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["components"],
  "properties": {
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "mpn", "manufacturer", "package", "symbol", "footprint", "pins", "lifecycle", "sourcing", "constraints", "resolution_provenance", "review_status"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "mpn": {"type": "string", "minLength": 1},
          "manufacturer": {"type": "string", "minLength": 1},
          "package": {"type": "string", "minLength": 1},
          "symbol": {
            "type": "object",
            "required": ["library_id", "verified", "expected_pins"],
            "properties": {"library_id": {"type": "string"}, "verified": {"type": "boolean"}, "expected_pins": {"type": "array", "minItems": 1, "items": {"type": "string"}}}
          },
          "footprint": {
            "type": "object",
            "required": ["library_id", "verified", "expected_pads"],
            "properties": {"library_id": {"type": "string"}, "verified": {"type": "boolean"}, "expected_pads": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "backend_footprints": {"type": "object", "properties": {"tscircuit": {"type": "string", "minLength": 1}}}}
          },
          "pins": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["number", "name", "electrical_type"]}},
          "lifecycle": {"enum": ["active", "nrnd", "obsolete"]},
          "sourcing": {
            "type": "object",
            "required": ["status", "supplier_skus"],
            "properties": {
              "status": {"enum": ["resolved", "waived", "unresolved"]},
              "supplier_skus": {"type": "array"},
              "waiver": {
                "type": "object",
                "required": ["reason", "risk", "mitigation", "approved_by", "approved_at", "required_reviews"],
                "properties": {
                  "reason": {"type": "string", "minLength": 1},
                  "risk": {"type": "string", "minLength": 1},
                  "mitigation": {"type": "string", "minLength": 1},
                  "approved_by": {"type": "string", "minLength": 1},
                  "approved_at": {"type": "string", "minLength": 1},
                  "required_reviews": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}
                },
                "additionalProperties": true
              }
            },
            "if": {"properties": {"status": {"const": "waived"}}},
            "then": {"required": ["waiver"]}
          },
          "constraints": {"type": "array"},
          "resolution_provenance": {"type": "object", "required": ["source", "reviewed_at"]},
          "review_status": {"enum": ["approved", "pending", "rejected"]}
        }
      }
    }
  }
}
