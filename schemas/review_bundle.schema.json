{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "review_bundle.schema.json",
  "title": "hw-codesign Review Bundle",
  "description": "Normalized snapshot of all gate reports and project metadata produced by hw export-review.",
  "type": "object",
  "required": ["bundle_version", "generated_at", "bundle_hash", "project", "gate_reports"],
  "additionalProperties": false,
  "properties": {
    "bundle_version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version; increment on breaking changes."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp of export; excluded from bundle_hash."
    },
    "bundle_hash": {
      "type": "string",
      "description": "SHA-256 hex digest of the canonical (generated_at-excluded) bundle content."
    },
    "project": {
      "type": "object",
      "required": ["name", "revision", "target_use", "backend"],
      "additionalProperties": false,
      "properties": {
        "name":       { "type": "string" },
        "revision":   { "type": "string" },
        "target_use": { "type": "string" },
        "backend":    { "type": "string" }
      }
    },
    "gate_reports": {
      "type": "array",
      "description": "All gate reports from the most recent run_all_checks pass, in stable sort order.",
      "items": {
        "type": "object",
        "required": ["gate", "status", "failures", "metrics", "artifacts", "backend"],
        "additionalProperties": false,
        "properties": {
          "gate":      { "type": "string" },
          "status":    { "type": "string", "enum": ["pass", "fail", "blocked", "candidate", "released"] },
          "failures":  {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["category", "code", "message", "severity"],
              "additionalProperties": true,
              "properties": {
                "category":             { "type": "string" },
                "code":                 { "type": "string" },
                "message":              { "type": "string" },
                "severity":             { "type": "string", "enum": ["error", "warning", "info"] },
                "path":                 { "type": ["string", "null"] },
                "details":              { "type": "object" },
                "requires_user_decision": { "type": "boolean" }
              }
            }
          },
          "metrics":   { "type": "object" },
          "artifacts": { "type": "array", "items": { "type": "string" } },
          "backend":   { "type": "object" }
        }
      }
    },
    "root_cause_analysis": {
      "type": "object",
      "description": "Root-cause DAG projection that folds downstream failures and orders repairs.",
      "additionalProperties": true,
      "properties": {
        "root_causes": {"type": "array", "items": {"type": "object"}},
        "top_root_causes": {"type": "array", "maxItems": 3, "items": {"type": "object"}},
        "affected_gates": {"type": "array", "items": {"type": "string"}},
        "repair_order": {"type": "array", "items": {"type": "string"}},
        "folded_gate_count": {"type": "integer"}
      }
    },
    "summary": {
      "type": "object",
      "description": "Aggregated pass/fail/blocked/total counts across all gate_reports.",
      "additionalProperties": false,
      "properties": {
        "total":   { "type": "integer" },
        "pass":    { "type": "integer" },
        "fail":    { "type": "integer" },
        "blocked": { "type": "integer" },
        "other":   { "type": "integer" }
      }
    },
    "placement": {
      "type": ["object", "null"],
      "description": "Placement proposal metadata; null when no components exist.",
      "additionalProperties": false,
      "properties": {
        "board_width_mm":    { "type": "number" },
        "board_height_mm":   { "type": "number" },
        "placement_count":   { "type": "integer" },
        "constraint_count":  { "type": "integer" },
        "source_counts":     { "type": "object", "additionalProperties": { "type": "integer" } },
        "unenforced_constraint_kinds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "three_d_preview": {
      "type": ["object", "null"],
      "description": "Optional native KiCad assembly preview sourced from existing standard-library 3D models.",
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string" },
        "reason": { "type": "string" },
        "source": { "type": "string" },
        "note": { "type": "string" },
        "model_count": { "type": "integer" },
        "available_model_count": { "type": "integer" },
        "interactive": { "type": "boolean" },
        "vrml_asset": { "type": ["string", "null"] },
        "fallback_image": { "type": ["string", "null"] },
        "viewer_asset": { "type": ["string", "null"] },
        "models": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "reference": { "type": "string" },
              "footprint": { "type": "string" },
              "model": { "type": "string" },
              "available": { "type": "boolean" }
            }
          }
        }
      }
    },
    "component_resolution": {
      "type": ["object", "null"],
      "description": "Component resolution summary; null when graph is absent.",
      "additionalProperties": false,
      "properties": {
        "resolved":          { "type": "integer" },
        "requested":         { "type": "integer" },
        "supplier_provider": { "type": "string" },
        "status":            { "type": "string" }
      }
    },
    "requirements": {
      "type": ["object", "null"],
      "description": "Requirements lowering summary; null when requirements.yaml is absent.",
      "additionalProperties": false,
      "properties": {
        "active_lowered_count":    { "type": "integer" },
        "active_unresolved_count": { "type": "integer" },
        "active_unresolved": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "id":               { "type": "string" },
              "source":           { "type": "string" },
              "category":         { "type": "string" },
              "status":           { "type": "string" },
              "release_blocking": { "type": "boolean" },
              "reason":           { "type": "string" }
            }
          }
        }
      }
    },
    "assumptions": {
      "type": ["object", "null"],
      "description": "Assumptions summary extracted from spec; null when absent.",
      "additionalProperties": false,
      "properties": {
        "total":                   { "type": "integer" },
        "unresolved_critical":     { "type": "integer" },
        "unresolved_critical_names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unresolved_critical_items": {
          "type": "array",
          "description": "Decision context retained from the spec for unresolved critical assumptions.",
          "items": {
            "type": "object",
            "required": ["name", "proposed_value", "confidence", "reason"],
            "additionalProperties": false,
            "properties": {
              "name":           { "type": "string" },
              "proposed_value": {},
              "confidence":     { "type": "string" },
              "reason":         { "type": "string" }
            }
          }
        }
      }
    },
    "comments": {
      "type": "array",
      "description": "Decisions/comments appended post-export via the comments sidecar; empty in the initial bundle.",
      "items": {
        "type": "object",
        "required": ["id", "timestamp", "text"],
        "additionalProperties": true,
        "properties": {
          "id":          { "type": "string" },
          "timestamp":   { "type": "string", "format": "date-time" },
          "text":        { "type": "string" },
          "author":      { "type": ["string", "null"] },
          "target_type": {
            "type": "string",
            "enum": ["general", "gate_failure", "requirement", "component"],
            "description": "Stable target type for this comment."
          },
          "target_id":   {
            "type": ["string", "null"],
            "description": "Stable target key, e.g. 'gate:footprint_check' or 'req_001'."
          },
          "bundle_hash": {
            "type": "string",
            "description": "bundle_hash of the snapshot this comment was made against."
          }
        }
      }
    },
    "iterations": {
      "type": "array",
      "description": "Lean summaries of design iterations from history/iterations/.",
      "items": {
        "type": "object",
        "required": ["iteration_id"],
        "additionalProperties": true,
        "properties": {
          "iteration_id": { "type": "string" },
          "created_at":   { "type": "string" },
          "goal":         { "type": "string" },
          "status":       { "type": "string" },
          "passed_gates": { "type": "array", "items": { "type": "string" } },
          "failed_gates": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "candidates": {
      "type": "array",
      "description": "Lean summaries of candidate snapshots from exports/candidates/.",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "release": {
      "type": ["object", "null"],
      "description": "Most recent release manifest summary; null when no release exists.",
      "additionalProperties": true,
      "properties": {
        "release_id":    { "type": "string" },
        "artifact_count": { "type": "integer" }
      }
    },
    "artifacts": {
      "type": "array",
      "description": "Review artifact evidence collected from gate reports and the latest release manifest. Missing references are preserved with exists=false.",
      "items": {
        "type": "object",
        "required": ["path", "source", "exists"],
        "additionalProperties": true,
        "properties": {
          "path":   { "type": "string" },
          "source": { "type": "string" },
          "sources": {
            "type": "array",
            "description": "All gate or manifest provenance categories that reference this de-duplicated path.",
            "items": { "type": "string" },
            "uniqueItems": true,
            "minItems": 1
          },
          "exists": { "type": "boolean" },
          "bytes":  { "type": "integer" },
          "sha256": { "type": "string" }
        }
      }
    }
  }
}
