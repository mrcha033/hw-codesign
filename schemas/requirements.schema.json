{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["raw_inputs", "active_lowered", "active_unresolved"],
  "properties": {
    "raw_inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "text", "created_by"],
        "properties": {
          "id": {"type": "string", "pattern": "^req_input_[0-9]{4,}$"},
          "text": {"type": "string", "minLength": 1},
          "created_by": {"type": "string", "minLength": 1}
        }
      }
    },
    "active_lowered": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "spec_path", "status"],
        "properties": {
          "id": {"type": "string"},
          "source": {"type": "string"},
          "spec_path": {"type": "string", "minLength": 1},
          "status": {"const": "lowered"}
        }
      }
    },
    "active_unresolved": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source", "category", "status", "release_blocking", "reason"],
        "properties": {
          "id": {"type": "string"},
          "source": {"type": "string", "minLength": 1},
          "category": {"type": "string", "minLength": 1},
          "field_type": {"enum": ["unsupported_constraint", "retained_assumption", "conflicting_lowered_field"]},
          "status": {"enum": ["unresolved", "waived"]},
          "release_blocking": {"type": "boolean"},
          "reason": {"type": "string", "minLength": 1},
          "required_human_approvals": {
            "type": "array",
            "items": {"type": "string"}
          },
          "affected_gates": {
            "type": "array",
            "items": {"type": "string"}
          },
          "assumption_key": {"type": "string"},
          "source_span": {"type": ["string", "null"]},
          "source_range": {
            "oneOf": [
              {"type": "null"},
              {
                "type": "object",
                "required": ["start", "end"],
                "properties": {
                  "start": {"type": "integer", "minimum": 0},
                  "end": {"type": "integer", "minimum": 0}
                }
              }
            ]
          }
        }
      }
    },
    "compiler_ir": {
      "type": "object",
      "required": ["version", "input_id", "lowered_fields", "unresolved_assumptions", "unsupported_constraints", "required_human_approvals", "affected_gates"],
      "properties": {
        "version": {"const": "requirements_ir_v1"},
        "input_id": {"type": "string"},
        "lowered_fields": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": true}
        },
        "unresolved_assumptions": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": true}
        },
        "unsupported_constraints": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": true}
        },
        "conflicting_fields": {
          "type": "array",
          "items": {"type": "object", "additionalProperties": true}
        },
        "required_human_approvals": {
          "type": "array",
          "items": {"type": "string"}
        },
        "affected_gates": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
