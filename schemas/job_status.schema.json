{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "hw-contracts JobStatus",
  "type": "object",
  "required": [
    "job_id",
    "status",
    "gate_events",
    "result"
  ],
  "additionalProperties": false,
  "properties": {
    "job_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "complete",
        "failed"
      ]
    },
    "gate_events": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "result": {
      "type": [
        "object",
        "null"
      ]
    }
  }
}
