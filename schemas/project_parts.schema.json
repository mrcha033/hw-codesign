{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Project-local component registrations",
  "type": "object",
  "required": ["version", "roles", "components"],
  "additionalProperties": false,
  "properties": {
    "version": {"const": 1},
    "roles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["component_id", "resolution"],
        "additionalProperties": false,
        "properties": {
          "component_id": {"type": "string", "minLength": 1},
          "resolution": {"const": "project_owned"},
          "rationale": {"type": "string", "minLength": 1}
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "role", "mpn", "manufacturer", "package", "symbol", "footprint", "pins", "electrical_ratings", "mechanical", "validation", "lifecycle", "sourcing", "constraints", "review_status"],
        "additionalProperties": true,
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "role": {"type": "string", "minLength": 1},
          "mpn": {"type": "string", "minLength": 1},
          "manufacturer": {"type": "string", "minLength": 1},
          "package": {"type": "string", "minLength": 1},
          "symbol": {
            "type": "object",
            "required": ["library_id", "verified", "expected_pins"],
            "properties": {
              "library_id": {"type": "string", "minLength": 1},
              "verified": {"type": "boolean"},
              "expected_pins": {"type": "array", "minItems": 1, "items": {"type": "string"}}
            }
          },
          "footprint": {
            "type": "object",
            "required": ["library_id", "verified", "expected_pads"],
            "properties": {
              "library_id": {"type": "string", "minLength": 1},
              "verified": {"type": "boolean"},
              "expected_pads": {"type": "array", "minItems": 1, "items": {"type": "string"}},
              "backend_footprints": {"type": "object"}
            }
          },
          "pins": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["number", "name", "electrical_type"],
              "properties": {
                "number": {"type": "string"},
                "name": {"type": "string"},
                "electrical_type": {"type": "string"},
                "voltage_domain": {"type": ["string", "null"]},
                "current_limit_a": {"type": ["number", "null"], "minimum": 0}
              }
            }
          },
          "electrical_ratings": {
            "type": "object",
            "required": ["supply_voltage_min_v", "supply_voltage_max_v", "current_continuous_a", "current_peak_a"],
            "properties": {
              "supply_voltage_min_v": {"type": "number"},
              "supply_voltage_max_v": {"type": "number"},
              "current_continuous_a": {"type": "number", "minimum": 0},
              "current_peak_a": {"type": "number", "minimum": 0}
            }
          },
          "mechanical": {
            "type": "object",
            "required": ["body_mm", "height_mm"],
            "properties": {
              "body_mm": {
                "type": "array",
                "prefixItems": [{"type": "number", "exclusiveMinimum": 0}, {"type": "number", "exclusiveMinimum": 0}],
                "minItems": 2,
                "maxItems": 2
              },
              "height_mm": {"type": "number", "exclusiveMinimum": 0},
              "model": {"type": ["string", "null"]},
              "mounting_holes": {"type": "array", "items": {"type": "object"}}
            }
          },
          "validation": {
            "type": "object",
            "required": ["status", "reviewer", "reviewed_at", "rules"],
            "properties": {
              "status": {"enum": ["approved", "pending", "rejected"]},
              "reviewer": {"type": "string", "minLength": 1},
              "reviewed_at": {"type": "string", "minLength": 1},
              "rules": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["id", "kind", "status", "constraint"],
                  "properties": {
                    "id": {"type": "string", "minLength": 1},
                    "kind": {"enum": ["pin_contract", "electrical_rating", "footprint", "mechanical", "sourcing", "custom"]},
                    "status": {"enum": ["pass", "blocked", "fail"]},
                    "constraint": {"type": "string", "minLength": 1},
                    "evidence": {"type": "array", "items": {"type": "string"}}
                  }
                }
              }
            }
          },
          "lifecycle": {"enum": ["active", "nrnd", "obsolete"]},
          "sourcing": {
            "type": "object",
            "required": ["status", "supplier_skus"],
            "properties": {
              "status": {"enum": ["resolved", "waived", "unresolved"]},
              "supplier_skus": {"type": "array"},
              "waiver": {"type": "object"}
            }
          },
          "constraints": {"type": "array"},
          "review_status": {"enum": ["approved", "pending", "rejected"]}
        }
      }
    }
  }
}
